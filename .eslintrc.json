{
  "root": true,
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "extends": ["airbnb-base", "prettier"],
  "plugins": ["prettier"],
  "ignorePatterns": ["dist/**/*.js", "scripts/**/*.mjs"],
  "rules": {
    "prettier/prettier": ["error"],
    "default-case": "off",
    "import/no-cycle": "off",
    "no-param-reassign": "off",
    "no-nested-ternary": "off",
    "no-underscore-dangle": ["error", { "allow": ["_imageCache", "_retryStats"] }]
  },
  "overrides": [
    {
      "files": ["tests/**/*.js", "vitest.config.js"],
      "env": { "jest": true, "node": true },
      "globals": { "vi": "readonly", "vitest": "readonly" }
    }
  ]
}
