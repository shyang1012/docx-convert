{
  "root": true,
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "extends": ["airbnb-base", "prettier"],
  "plugins": ["prettier"],
  "ignorePatterns": ["dist/**/*.js", "scripts/**/*.mjs"],
  "rules": {
    "prettier/prettier": ["error"],
    "default-case": "off",
    "import/no-cycle": "off",
    "no-param-reassign": "off",
    "no-nested-ternary": "off",
    "no-underscore-dangle": ["error", { "allow": ["_imageCache", "_retryStats"] }],
    "no-continue": "off",
    "no-restricted-syntax": "off",
    "import/prefer-default-export": "off",
    "no-lonely-if": "off",
    "no-use-before-define": "off",
    "class-methods-use-this": "off",
    "no-cond-assign": ["error", "except-parens"],
    "no-console": "warn"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js", "vitest.config.js"],
      "env": { "jest": true, "node": true },
      "globals": { "vi": "readonly", "vitest": "readonly" }
    }
  ]
}
