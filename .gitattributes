# Normalize line endings to LF in the repo (working tree may be CRLF on Windows via
# core.autocrlf, but git stores LF). Keeps prettier/eslint from flagging CRLF and
# eliminates spurious whole-file diffs across platforms. [shyang 2026-06-22]
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.docx binary
*.xlsx binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
